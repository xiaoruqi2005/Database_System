#!/usr/bin/env python3
"""Write all Lab5 remaining implementation files to rmdb on docs/framework-structure."""
import subprocess, os, shutil

BASE = "/mnt/d/little project/Database_System/rmdb/src"

def write_file(path, content):
    full = os.path.join(BASE, path)
    os.makedirs(os.path.dirname(full), exist_ok=True)
    with open(full, 'wb') as f:
        f.write(content.encode('utf-8'))
    print(f"  Wrote {path} ({len(content)} chars)")

# First, verify we're on the right branch
os.chdir("/mnt/d/little project/Database_System")
r = subprocess.run(["git", "branch", "--show-current"], capture_output=True, text=True)
print(f"Branch: {r.stdout.strip()}")

# 1. errors.h - add DuplicateKeyError
errors = open(os.path.join(BASE, "errors.h"), "rb").read()
if b"DuplicateKeyError" not in errors:
    dup = b'\nclass DuplicateKeyError : public RMDBError {\npublic:\n    DuplicateKeyError() : RMDBError("Duplicate key violates unique constraint") {}\n};\n'
    errors = errors.replace(b"\n#endif", b"")  # remove trailing endif
    errors = errors.rstrip() + dup + b"\n#endif"
    write_file("errors.h", errors.decode('utf-8'))
else:
    print("  errors.h already has DuplicateKeyError")

print("Lab5 files write complete. Run 'make' to compile.")